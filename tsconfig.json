{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "baseUrl": ".",
        "paths": {
            "obsidian": [
                "node_modules/obsidian/obsidian.d.ts"
            ]
        },
        "esModuleInterop": true
    },
    "include": [
        "**/*.ts"
    ]
}